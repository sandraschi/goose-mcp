# goose-mcp environment config
# Copy to .env and edit as needed

# Path to goose binary (auto-detected from PATH if not set)
# GOOSE_BIN=C:\Users\sandr\.local\bin\goose.exe

# Directory for session logs
# GOOSE_MCP_DATA_DIR=D:\Dev\repos\goose-mcp\data

# Disable Prefab UI tools (set to 0 in CI/headless)
# GOOSE_PREFAB_APPS=1

# Log level
# GOOSE_MCP_LOG_LEVEL=INFO

# Port overrides (default: 10948 backend, 10949 frontend)
# GOOSE_MCP_BACKEND_PORT=10948
# GOOSE_MCP_FRONTEND_PORT=10949
